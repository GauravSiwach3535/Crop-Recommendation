# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-secrets-module
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (leave blank for SQLite dev default) ──
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# For PostgreSQL on prod:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=cropai
# DB_USER=cropai_user
# DB_PASSWORD=strongpassword
# DB_HOST=localhost
# DB_PORT=5432

# ── CORS (comma-separated) ──
CORS_ORIGINS=http://localhost:3000

# ── ML model paths (defaults to backend/ml/) ──
# ML_MODEL_PATH=/absolute/path/to/crop_model.joblib
# ML_ENCODER_PATH=/absolute/path/to/label_encoder.joblib
